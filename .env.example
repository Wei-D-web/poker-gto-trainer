# ==========================================
# PokerGTO Trainer — Environment Variables
# ==========================================
# Copy this to .env and fill in your values.

# ── Dev Build Flag (set to true for local dev, false for customers) ──
VITE_POKERGTO_DEV_BUILD=false

# ── Supabase (Auth + Database) ──────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side only, NEVER expose in frontend code.
# Used by the migration script (scripts/migrate-presets-to-supabase.ts)
# to bypass RLS and write preset strategy data.
# Get it from: https://app.supabase.com → Project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (Payments) ───────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
#
# Publishable key (safe for frontend):
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Price IDs (create in Stripe Dashboard → Products):
#   Pro Monthly:  $29.99/month subscription
#   Pro Yearly:   $219/year subscription (save $140)
#   Lifetime:     $299 one-time payment
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxxxxx
VITE_STRIPE_PRICE_PRO_YEARLY=price_xxxxxx
VITE_STRIPE_PRICE_LIFETIME=price_xxxxxx

# ── Stripe Secrets (for Edge Functions / Webhooks) ──
# DO NOT prefix with VITE_ — these are server-side only!
# Set these in Supabase Dashboard → Project → Settings → Edge Functions → Secrets
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── License Key Signing Secret ──
# HMAC-SHA256 key used to sign and validate customer license keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_LICENSE_SECRET=your-64-char-random-hex-secret-here

# ── Supabase Auth Providers ─────────────────────────
# Enable in Supabase Dashboard → Authentication → Providers:
#   - Google (OAuth 2.0)
#   - Discord (OAuth 2.0)
#
# Then configure redirect URLs:
#   https://<project>.supabase.co/auth/v1/callback
