{
  "name": "poker-gto-trainer",
  "version": "0.1.0",
  "description": "GTO Poker Training Desktop App — preflop ranges, postflop strategies, training mode",
  "main": "./out/main/index.js",
  "author": "PokerGTO",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.config.web.mts",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.config.web.mts",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "html2canvas-pro": "^2.0.4",
    "lru-cache": "^11.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "sql.js": "^1.12.0",
    "stripe": "^22.2.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/d3": "^7.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
